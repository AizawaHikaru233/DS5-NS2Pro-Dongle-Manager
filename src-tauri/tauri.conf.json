{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DS5 NS2Pro Dongle Manager",
  "version": "1.0.0",
  "identifier": "com.ds5ns2prodongle.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DS5 NS2Pro Dongle Manager",
        "width": 1400,
        "height": 800,
        "minWidth": 1400,
        "minHeight": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "shortDescription": "A desktop manager for a Pico-based DS5 and NS2Pro dongle bridge.",
    "longDescription": "A desktop manager for a Pico-based DS5 and NS2Pro dongle bridge, focused on configuring firmware, device status, and future NS2Pro-to-DualSense translation.",
    "icon": [
      "icons/pwa-icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/sounds/controller-connected.wav",
      "resources/sounds/controller-disconnected.wav",
      "resources/sounds/controller-low-battery.wav"
    ]
  }
}
